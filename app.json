{
  "expo": {
    "name": "CryptoPortfolio",
    "slug": "CryptoPortfolio",
    "description": "CryptoPortfolio is a professional mobile crypto tracker for monitoring holdings, imports, PnL, and live market performance with fast charts and reliable local data.",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cryptoportfolio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.belcebuu.CryptoPortfolio",
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2B4A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.belcebuu.CryptoPortfolio",
      "versionCode": 3
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/branding-source.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#0F2B4A",
          "dark": {
            "backgroundColor": "#070F1C"
          }
        }
      ],
      "expo-localization",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d6b089c-8186-419d-85ec-b42787910c1e"
      }
    }
  }
}
